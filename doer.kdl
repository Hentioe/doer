tasks {
    // 一个包含参数、选项、环境变量和用户的例子
    hello {
        - "echo Hello {name}! My age is {age}. The env FOO is $FOO."
        arg name
        opt age=18
        user root
        env {
            FOO bar
        }
    }
    // 一个让依赖任务在后台运行的例子
    ping {
        - "echo starting ping..."
        - "ping localhost"
    }
    start-ping {
        - "echo ping will start in background..."
        dep ping {
            background
            // background #true // <- 或手动指定为 true
        }
    }
    // 一个多命令任务的例子
    precommit {
        - "cargo fmt --all -- --check"
        - "cargo clippy --all-targets -- -D warnings"
    }
    // 一个无命令任务的例子
    prepush {
        dep precommit
        dep test {
            stdout void // <- todo: 支持管理依赖任务的 stdio
        }
    }
    format "cargo fmt"
    build "cargo build"
    test {
        - "cargo test --all"
        opt stdout=default
        stdout "{stdout}"
        dep format
    }
    cleanup "cargo clean"
    install {
        - "cargo install --path {path} --bin {bin}"
        arg path
        opt bin=doer
        dep test
        dep setcap {
            arg "{bin}"
            opt mode=release
        }
    }
    run {
        - "cargo run --bin {bin}"
        arg bin
        dep build
        dep setcap {
            arg "{bin}"
        }
    }
    release {
        - "cargo build --bin {bin} --release"
        arg bin
        dep test
        dep setcap {
            arg "{bin}"
            opt mode=release
        }
        env {
            RUST_BACKTRACE full
        }
    }
    setcap {
        - "setcap 'cap_sys_nice=+ep' {bin}"
        cwd "target/{mode}"
        arg bin
        opt mode=debug
        user root
    }
}
